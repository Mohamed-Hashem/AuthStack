# MongoDB Connection (required)
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/cinema-house

# JWT Configuration (required)
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Server Configuration (local dev only — Vercel sets PORT automatically)
PORT=5000
NODE_ENV=development

# CORS — comma-separated list of allowed browser origins.
# Use `*` to reflect any origin (dev / public starter APIs).
# Leave unset to use built-in defaults (localhost + 127.0.0.1 on ports 3000, 5173, 5174).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:3001